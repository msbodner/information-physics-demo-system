{
  "name": "information-physics-demo-system",
  "version": "4.5.0",
  "description": "Information Physics Demo System \u2014 InformationPhysics.ai Desktop Application",
  "author": "Michael Simon Bodner, Ph.D. <bodner.michael@gmail.com>",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "bash -c 'set -a; [ -f .env ] && source .env; set +a; electron-builder'",
    "dist:mac": "bash -c 'set -a; [ -f .env ] && source .env; set +a; electron-builder --mac'",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "prepare-resources": "bash scripts/build-resources.sh"
  },
  "build": {
    "appId": "ai.informationphysics.aio-system",
    "productName": "Information Physics Demo System",
    "copyright": "Copyright 2026 InformationPhysics.ai, LLC",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "resources/python",
        "to": "python",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/frontend",
        "to": "frontend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/postgres",
        "to": "postgres",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "icons/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": {
        "teamId": "P4CWP6XFVD"
      }
    },
    "win": {
      "target": "nsis",
      "icon": "icons/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icons/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "tree-kill": "^1.2.2"
  }
}
