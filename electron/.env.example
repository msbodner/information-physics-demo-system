# Electron build — code signing & notarization environment variables
#
# Copy this file to electron/.env and fill in real values to enable
# signed + notarized DMGs. The .env file is gitignored.
#
# When all three vars below are set AND a Developer ID Application
# certificate is installed in Keychain, `npm run dist` produces:
#   1. A signed .app bundle (Developer ID Application: <Your Name>)
#   2. Stapled, notarized DMGs that launch on any Mac with no warning
#
# When unset, the build still works — it just skips signing and
# produces unsigned DMGs (right-click → Open required on first launch).

# Apple ID email associated with your Apple Developer Program membership
APPLE_ID=

# App-specific password for the Apple ID above.
# Generate one at https://appleid.apple.com → Sign-In and Security →
# App-Specific Passwords. Label it something like "electron-builder
# notarization". Format: xxxx-xxxx-xxxx-xxxx
APPLE_APP_SPECIFIC_PASSWORD=

# Apple Team ID (10-character string).
# Find it at https://developer.apple.com/account → Membership.
# Already configured for InformationPhysics.ai in package.json
# (build.mac.notarize.teamId), but electron-builder also reads this
# env var as a fallback. Set to the same value for safety.
APPLE_TEAM_ID=P4CWP6XFVD
